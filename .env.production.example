# ================================================
# Juvenal CRM - Production Environment Variables
# ================================================
# Copie este arquivo e configure no Easypanel
# NUNCA commit este arquivo com valores reais!
# ================================================

# -----------------
# Node Environment
# -----------------
NODE_ENV=production

# -----------------
# Server Configuration
# -----------------
PORT=3001

# -----------------
# Supabase Configuration
# -----------------
# Obtenha estas informações em: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------
# Security Secrets
# -----------------
# IMPORTANTE: Use strings aleatórias fortes em produção!
# Você pode gerar com: openssl rand -base64 32

# Secret para assinar/validar API Keys
API_KEY_SECRET=your-api-key-secret-here

# Secret para assinar/validar JWT tokens
JWT_SECRET=your-jwt-secret-here

# -----------------
# CORS Configuration
# -----------------
# Separe múltiplos domínios com vírgula (sem espaços)
# Exemplo: https://app.exemplo.com,https://www.exemplo.com
ALLOWED_ORIGINS=https://seu-dominio.com

# -----------------
# Rate Limiting (Opcional)
# -----------------
# Janela de tempo em milissegundos (padrão: 60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# Máximo de requests por janela (padrão: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ================================================
# Frontend Environment Variables (se separado)
# ================================================
# Estas variáveis são necessárias apenas se você
# estiver deployando o frontend separadamente

# URL do Supabase (para autenticação no frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key do Supabase (NÃO é a service role key!)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ================================================
# Gerar Secrets Aleatórios
# ================================================
# Execute estes comandos para gerar secrets fortes:
#
# No Linux/Mac:
#   openssl rand -base64 32
#
# No Node.js:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Online (use com cuidado):
#   https://generate-secret.vercel.app/32
#
# ================================================
